using System;
using System.IO;
using System.Text;
using System.Threading;

namespace LoggingSystem
{
    /// <summary>
    /// Класс логгера, реализованный по паттерну Singleton
    /// Обеспечивает единственную точку записи логов в файл или консоль
    /// </summary>
    public sealed class Logger
    {
        private static readonly Lazy<Logger> _instance = new Lazy<Logger>(() => new Logger());
        private static readonly object _lockObject = new object();
        private readonly string _logFilePath;
        private readonly bool _logToFile;
        private readonly bool _logToConsole;

        // Приватный конструктор предотвращает создание экземпляров извне
        private Logger()
        {
            _logFilePath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "app.log");
            _logToFile = true;
            _logToConsole = true;
        }

        /// <summary>
        /// Глобальная точка доступа к единственному экземпляру
        /// </summary>
        public static Logger Instance => _instance.Value;

        /// <summary>
        /// Запись информационного сообщения
        /// </summary>
        public void Info(string message)
        {
            LogMessage("INFO", message);
        }

        /// <summary>
        /// Запись сообщения об ошибке
        /// </summary>
        public void Error(string message, Exception ex = null)
        {
            string fullMessage = message;
            if (ex != null)
            {
                fullMessage += $"\nException: {ex.Message}\nStackTrace: {ex.StackTrace}";
            }
            LogMessage("ERROR", fullMessage);
        }

        /// <summary>
        /// Запись предупреждения
        /// </summary>
        public void Warning(string message)
        {
            LogMessage("WARNING", message);
        }

        /// <summary>
        /// Запись отладочного сообщения
        /// </summary>
        public void Debug(string message)
        {
            LogMessage("DEBUG", message);
        }

        /// <summary>
        /// Основной метод логирования
        /// </summary>
        private void LogMessage(string level, string message)
        {
            string timestamp = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff");
            string logEntry = $"[{timestamp}] [{level}] {message}";

            lock (_lockObject) // Блокировка для потокобезопасности
            {
                if (_logToConsole)
                {
                    WriteToConsole(logEntry, level);
                }

                if (_logToFile)
                {
                    WriteToFile(logEntry);
                }
            }
        }

        /// <summary>
        /// Запись в консоль с цветом в зависимости от уровня
        /// </summary>
        private void WriteToConsole(string message, string level)
        {
            ConsoleColor originalColor = Console.ForegroundColor;

            switch (level)
            {
                case "ERROR":
                    Console.ForegroundColor = ConsoleColor.Red;
                    break;
                case "WARNING":
                    Console.ForegroundColor = ConsoleColor.Yellow;
                    break;
                case "INFO":
                    Console.ForegroundColor = ConsoleColor.Green;
                    break;
                case "DEBUG":
                    Console.ForegroundColor = ConsoleColor.Gray;
                    break;
            }

            Console.WriteLine(message);
            Console.ForegroundColor = originalColor;
        }

        /// <summary>
        /// Запись в файл
        /// </summary>
        private void WriteToFile(string message)
        {
            try
            {
                File.AppendAllText(_logFilePath, message + Environment.NewLine, Encoding.UTF8);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to write to log file: {ex.Message}");
            }
        }

        /// <summary>
        /// Очистка логов
        /// </summary>
        public void ClearLogs()
        {
            lock (_lockObject)
            {
                if (File.Exists(_logFilePath))
                {
                    File.Delete(_logFilePath);
                }
            }
        }
    }
class Program
{
    static void Main(string[] args)
    {
        // Получаем единственный экземпляр логгера
        Logger logger = Logger.Instance;

        logger.Info("Приложение запущено");
        logger.Debug("Загрузка конфигурации...");
        logger.Warning("Предупреждение: низкий уровень памяти");
        
        try
        {
            // Какой-то код
            throw new Exception("Тестовая ошибка");
        }
        catch (Exception ex)
        {
            logger.Error("Произошла ошибка", ex);
        }

        logger.Info("Приложение завершено");
        Console.ReadKey();
    }
}
